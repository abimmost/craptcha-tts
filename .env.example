# Telegram API Credentials (from https://my.telegram.org)
TG_API_ID=your_api_id_here
TG_API_HASH="your_api_hash_here"

# The ID of the group where topics are hosted
TG_TARGET_GROUP_ID="Group ID here"

# Identity Spoofing (Optional but recommended)
TG_DEVICE_MODEL="Desktop"
TG_SYSTEM_VERSION="Windows 11"
TG_APP_VERSION="1.0.0"

# Gemini API Key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your_gemini_api_key_here"

CORS_ORIGIN="Your origins here"
